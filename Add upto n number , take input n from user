import java.util.*;

public class Demo {

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        System.out.println("Enter number you Add upto :");
        int n = sc.nextInt();

        int sum = 0;

        for (int i = 0; i <= n; i++) {

            sum = sum + i;

        }

        System.out.println("The sum is : " + sum);
    }
}
